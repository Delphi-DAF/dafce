<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    </PropertyGroup>
    <ItemGroup>
        <Projects Include="test\CommonsSpecs.dproj">
            <Dependencies/>
        </Projects>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Default.Personality.12</Borland.Personality>
        <Borland.ProjectType/>
        <BorlandProject>
            <Default.Personality/>
        </BorlandProject>
    </ProjectExtensions>
    <Target Name="CommonsSpecs">
        <MSBuild Projects="test\CommonsSpecs.dproj"/>
    </Target>
    <Target Name="CommonsSpecs:Clean">
        <MSBuild Projects="test\CommonsSpecs.dproj" Targets="Clean"/>
    </Target>
    <Target Name="CommonsSpecs:Make">
        <MSBuild Projects="test\CommonsSpecs.dproj" Targets="Make"/>
    </Target>
    <Target Name="Build">
        <CallTarget Targets="CommonsSpecs"/>
    </Target>
    <Target Name="Clean">
        <CallTarget Targets="CommonsSpecs:Clean"/>
    </Target>
    <Target Name="Make">
        <CallTarget Targets="CommonsSpecs:Make"/>
    </Target>
    <Import Project="$(BDS)\Bin\CodeGear.Group.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Group.Targets')"/>
</Project>
